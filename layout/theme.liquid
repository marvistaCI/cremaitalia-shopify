<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#FBF8F1">

  <title>
    {%- if template.name == 'index' -%}
      {{ shop.name }} &mdash; {{ page_title }}
    {%- elsif page_title == blank -%}
      {{ shop.name }}
    {%- else -%}
      {{ page_title }} &mdash; {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Google Fonts: Cormorant Garamond + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  >

  {{ content_for_header }}

  {{ 'crema-italia.css' | asset_url | stylesheet_tag }}
</head>

<body>
  <div class="page-wrapper">
    {{ content_for_layout }}
  </div>

  <script src="{{ 'crema-italia.js' | asset_url }}" defer></script>
</body>
</html>
