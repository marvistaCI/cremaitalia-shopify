<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#FBF8F1">

  <title>
    {%- if template.name == 'index' -%}
      {{ shop.name }} - Italian Artisan Coffee, Imported Without Compromise
    {%- elsif page_title == blank -%}
      {{ shop.name }}
    {%- else -%}
      {{ page_title }} - {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="icon" type="image/png" sizes="32x32" href="{{ 'ci-favicon-32.png' | asset_url }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ 'ci-favicon-16.png' | asset_url }}">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ 'ci-apple-touch-icon.png' | asset_url }}">

  <!-- Google Fonts: Marcellus (display) + Inter (body). Rebrand 2026-07-01: display = Marcellus (web stand-in for logo font Montecatini Pro). -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Marcellus&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  >

  {{ content_for_header }}

  {{ 'ci-storefront.css' | asset_url | stylesheet_tag }}

  <!-- POC3: baked-in test dataset location for the storefront JS. -->
  <script>window.CI_CATALOG_URL = {{ 'ci-catalog.json' | asset_url | json }};</script>
  <!-- Resolves catalog `people[].photo` filenames to real asset URLs for the JS-rendered
       person page. PROD: real team/partner records carry their own image URLs. -->
  <script>window.CI_ASSETS = {
    "ci-lucia.jpg": {{ 'ci-lucia.jpg' | asset_url | json }},
    "ci-asia.jpg": {{ 'ci-asia.jpg' | asset_url | json }}
  };</script>
</head>

<body>
  {% render 'ci-header' %}
  {% render 'ci-profile-banner' %}

  {{ content_for_layout }}

  {% render 'ci-store-footer' %}
  <div class="flag-strip flag-bottom" aria-hidden="true"><div></div><div></div><div></div></div>

  {% render 'ci-quiz-modal' %}
  {% render 'ci-signin-modal' %}
  {% render 'ci-taste-console' %}
  <div class="toast" id="ci-toast" role="status" aria-live="polite"></div>

  <script src="{{ 'ci-storefront.js' | asset_url }}" defer></script>
</body>
</html>
