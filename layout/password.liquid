<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#FBF8F1">

  <title>{{ shop.name }}</title>

  <meta name="description" content="Italian coffee, brought over whole. Opening late Summer/Fall 2026.">

  <!-- Open Graph / social share preview -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Crema Italia &mdash; Italian coffee, brought over whole.">
  <meta property="og:description" content="A small group of artisan Italian roasters, brought to the U.S. Opening late Summer/Fall 2026. Sign up for advance notice.">
  <meta property="og:image" content="{{ 'ci-og-image.png' | asset_url }}">
  <meta property="og:url" content="{{ shop.url }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Crema Italia &mdash; Italian coffee, brought over whole.">
  <meta name="twitter:description" content="A small group of artisan Italian roasters, brought to the U.S. Opening late Summer/Fall 2026. Sign up for advance notice.">
  <meta name="twitter:image" content="{{ 'ci-og-image.png' | asset_url }}">

  <!--
    Shopify requires content_for_header in the password layout to inject
    storefront-renderer scripts and analytics. See:
    https://shopify.dev/docs/themes/architecture/layouts#required-variables
  -->
  {{ content_for_header }}

  <!-- Google Fonts: Marcellus + Inter (rebrand 2026-07-01) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Marcellus&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  >

  {{ 'crema-italia.css' | asset_url | stylesheet_tag }}
</head>

<body>
  <div class="page-wrapper">
    <!--
      content_for_layout renders templates/password.liquid when
      password protection is enabled in the Shopify admin.
      See: https://shopify.dev/docs/themes/architecture/templates/password
    -->
    {{ content_for_layout }}
  </div>

  <script src="{{ 'crema-italia.js' | asset_url }}" defer></script>
</body>
</html>
