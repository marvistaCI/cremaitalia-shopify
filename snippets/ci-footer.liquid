{%- comment -%}
  snippets/ci-footer.liquid
  Shared site footer. Included on every page with {% render 'ci-footer' %}.
  Single source of truth so the company line and links stay identical
  everywhere — edit here once, every page updates.
{%- endcomment -%}
<footer class="ci-footer" role="contentinfo">
  <div class="ci-footer__inner">
    <div class="tricolore-rule" aria-hidden="true"></div>
    <p class="ci-footer__line">Crema Italia, LLC &middot; Lutz, Florida, USA &middot; cremaitalia.com</p>
    <ul class="ci-footer__links">
      <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
      <li><a href="mailto:info@cremaitalia.com">Contact</a></li>
      <li><a href="https://instagram.com/cremaitalia" target="_blank" rel="noopener noreferrer">@cremaitalia</a></li>
    </ul>
  </div>
</footer>
