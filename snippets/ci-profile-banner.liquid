{%- comment -%}
  ci-profile-banner.liquid — global taste-profile ribbon.
  Shown ONLY on the Shop + shelf pages, and ONLY when a taste profile exists
  (visibility + state driven by updateRibbon/renderRibbon in ci-storefront.js).
  Toggles taste filtering on/off; "Edit profile" opens the taste console modal.
{%- endcomment -%}
<div class="taste-ribbon" id="taste-ribbon">
  <div class="flag-strip taste-ribbon-flag" aria-hidden="true"><div></div><div></div><div></div></div>
  <div class="taste-ribbon-inner">
    <div class="tr-main">
      <span class="tr-dot" aria-hidden="true"></span>
      <p class="tr-status" id="tr-status"></p>
      <div class="profile-tags tr-tags" id="tr-tags"></div>
    </div>
    <div class="tr-actions">
      <button class="tr-edit" onclick="openTasteConsole()">Edit profile</button>
      <button class="tr-toggle" id="tr-toggle" onclick="toggleProfileFilter()">Apply profile</button>
    </div>
  </div>
</div>
