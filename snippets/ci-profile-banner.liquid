{%- comment -%} ci-profile-banner.liquid — taste-profile active banner (shown after the quiz). {%- endcomment -%}
<div class="profile-banner" id="profile-banner">
  <div class="profile-banner-inner">
    <p>Your taste profile is active — catalog filtered to your preferences.</p>
    <div class="profile-tags" id="profile-banner-tags"></div>
    <button class="btn btn-outline" style="font-size:.78rem;padding:.3rem .75rem;border-color:rgba(255,255,255,.3)" onclick="clearProfile()">Clear profile</button>
  </div>
</div>
