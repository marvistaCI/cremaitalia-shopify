<!--
  templates/password.liquid
  Crema Italia — Coming Soon (pre-launch) page.

  This is the page visitors actually see WHILE the storefront is password
  protected (Online Store > Preferences > "Password protect your storefront"
  = ON). It captures email signups for the pre-launch newsletter.

  It is wrapped by layout/password.liquid. When you launch, turn password
  protection OFF and templates/index.liquid becomes the live homepage
  instead. See README.md / CLAUDE.md.
-->
<section class="ci-section ci-hero">
  <div class="ci-section__inner">
    <span class="eyebrow">Italian by Nature</span>
    <h1>Italian coffee, brought over whole.</h1>
    <div class="tricolore-rule" aria-hidden="true"></div>
    <p class="subheading">
      Crema Italia carefully imports origin&#8209;true Italian roasters directly
      to the U.S. &mdash; never re&#8209;roasted, ground, or repackaged by us.
      Opening Summer/Fall 2026.
    </p>
  </div>
</section>

<section class="ci-section ci-signup">
  <div class="ci-section__inner">
    <div class="signup-card" id="signup-card">
      {%- comment -%}
        Shopify's {% form 'customer' %} does a normal server-side POST and
        sets form.posted_successfully? on the way back. The JS in
        assets/crema-italia.js is optional polish on top (typo check,
        double-submit guard, screen-reader announce).
      {%- endcomment -%}
      {% form 'customer', id: 'PreLaunchSignup', class: 'signup-form' %}
        {% if form.posted_successfully? %}
          <div class="form-success is-visible" role="status">
            <h3>Grazie.</h3>
            <p>We have your address. We will write when the first pallet lands.</p>
          </div>
        {% else %}
          <h3>Be the first to know.</h3>
          <p class="card-body">
            Join the pre&#8209;launch list and we will write to you once &mdash;
            when the store opens. No noise in between.
          </p>

          {{ form.errors | default_errors }}

          <input type="hidden" name="contact[tags]" value="prelaunch-crema-italia, prospect, coming-soon">

          <div class="form-row">
            <input
              type="email"
              name="contact[email]"
              required
              placeholder="Email address"
              aria-label="Email address"
              autocomplete="email"
            >
            <button type="submit">Notify me</button>
          </div>

          <p class="form-error" role="alert" aria-hidden="true">
            That does not look like a valid email &mdash; try again?
          </p>

          <p class="form-microcopy">
            We use your address only for the pre&#8209;launch announcement.
            Unsubscribe anytime.
          </p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

<details class="ci-password-entry">
  <summary>Enter using password</summary>
  {% form 'storefront_password' %}
    {{ form.errors | default_errors }}
    <div class="form-row">
      <input
        type="password"
        name="password"
        placeholder="Password"
        aria-label="Store password"
        required
      >
      <button type="submit" class="ci-btn">Enter</button>
    </div>
  {% endform %}
</details>

{% render 'ci-footer' %}
