<div class="page" id="page-contact">
  <main class="ci-main">
    <button class="back-btn" onclick="goBack()">&larr; Back</button>
    <div class="section-head" style="margin-top:0"><p class="eyebrow">Get in touch</p><h2>Contact us</h2></div>
    <div class="prose" style="max-width:60ch">
      <p>Questions about an order, a roaster, or anything else... send a note and it reaches the right desk. We read every message.</p>
    </div>
    <!-- PROD: this send is MOCKED (no backend in the POC). Wire the real send one of two ways:
         (a) a form/contact app that routes by the "reason" value to info@ / support@ / contact@, or
         (b) Shopify's native contact-form tag (form 'contact') to a single inbox (contact@) with the
         reason carried in the subject/body for a mail filter to fan out. Mailboxes contact@/info@/support@
         must exist. Radio (one destination), default "Other". See docs/POC9_change_list.md. -->
    <form class="contact-form" id="contact-form" onsubmit="return submitContact(event)" novalidate>
      <div class="cf-field">
        <label for="cf-name">Name</label>
        <input id="cf-name" name="name" type="text" required autocomplete="name">
      </div>
      <div class="cf-field">
        <label for="cf-email">Email</label>
        <input id="cf-email" name="email" type="email" required autocomplete="email">
      </div>
      <div class="cf-field">
        <label for="cf-phone">Phone <span class="cf-opt">(optional)</span></label>
        <input id="cf-phone" name="phone" type="tel" autocomplete="tel">
      </div>
      <fieldset class="cf-field cf-reason">
        <legend>How can we help?</legend>
        <label class="cf-radio"><input type="radio" name="reason" value="info"> More info</label>
        <label class="cf-radio"><input type="radio" name="reason" value="support"> I need help</label>
        <label class="cf-radio"><input type="radio" name="reason" value="other" checked> Other</label>
      </fieldset>
      <div class="cf-field">
        <label for="cf-message">Message</label>
        <textarea id="cf-message" name="message" rows="5" required></textarea>
      </div>
      <p class="cf-error" id="cf-error" role="alert" hidden></p>
      <button type="submit" class="btn btn-primary">Send</button>
    </form>
  </main>
</div>

