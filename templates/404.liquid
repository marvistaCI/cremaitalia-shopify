<!--
  templates/404.liquid
  Crema Italia — Branded 404 (page not found)
-->
<section class="ci-section ci-hero">
  <div class="ci-section__inner">
    <span class="eyebrow">Pagina non trovata</span>
    <h1>That page does not exist.</h1>
    <div class="tricolore-rule" aria-hidden="true"></div>
    <p class="subheading">
      The page you are looking for may have moved or been removed.
    </p>
    <a href="{{ routes.root_url }}" class="ci-btn ci-btn--inline">Return home</a>
  </div>
</section>

{% render 'ci-footer' %}
